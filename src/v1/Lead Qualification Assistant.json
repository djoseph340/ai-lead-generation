    {
      "parameters": {
        "jsCode": " const lead = $input.item.json;\n  const data = lead.body ?? lead;\n\n  // Extract fields from Tally's nested structure\n  const fields = data.data?.fields || [];\n  const fieldMap = {};\n\n  // Convert fields array into an object by label\n  fields.forEach(field => {\n    const label = field.label.toLowerCase();\n    fieldMap[label] = field.value;\n  });\n\n  let score = 0;\n\n  // Industry scoring\n  const industry = (fieldMap['industry'] || \"\").toLowerCase();\n  if (industry === \"healthcare\") {\n    score += 30;\n  }\n\n  // Company size scoring\n  const employees = Number(fieldMap['number of employees'] || 0);\n  if (employees >= 200) {\n    score += 25;\n  }\n\n  // Interest scoring\n  const message = (fieldMap['message'] || \"\").toLowerCase();\n\n  if (message.includes(\"ai\")) {\n    score += 20;\n  }\n\n  if (message.includes(\"automation\")) {\n    score += 20;\n  }\n\n  // Priority\n  let priority = \"Low\";\n\n  if (score >= 80) {\n    priority = \"High\";\n  } else if (score >= 50) {\n    priority = \"Medium\";\n  }\n\n  // Return updated item\n  const result = {\n    name: fieldMap['name'] || '',\n    company: fieldMap['company'] || '',\n    email: fieldMap['email'] || '',\n    industry: fieldMap['industry'] || '',\n    employees: fieldMap['number of employees'] || '',\n    message: fieldMap['message'] || '',\n    lead_score: score,\n    priority: priority\n  };\n\n  return { json: result };"
      },
      "type": "n8n-nodes-base.code",
