    {
      "parameters": {
        "jsCode": " const score = Number($json.lead_score);\n\n  let tier = \"\";\n  let reason_codes = [];\n\n  // Tiering logic\n  if (score >= 60) {\n    tier = \"Tier A - Close Miss\";\n    if (score < 80) reason_codes.push(\"insufficient_score\");\n  } else if (score >= 40) {\n    tier = \"Tier B - Weak Fit\";\n    reason_codes.push(\"weak_role_fit\");\n  } else {\n    tier = \"Tier C - No Fit\";\n    reason_codes.push(\"junior_level_mismatch\");\n  }\n\n  return [\n    {\n      json: {\n        ...$json,\n        tier,\n        reason_codes: reason_codes.join(\", \")\n      }\n    }\n  ];"
      },
